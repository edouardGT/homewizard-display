  "description": "HomeWizard energy dashboard backend — live data, history, analytics, costs",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
