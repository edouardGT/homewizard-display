# --- Server ---
PORT=5050
DB_PATH=./data/energy.db
SAMPLE_INTERVAL_MS=10000

# --- P1 meter (v2 API, HTTPS + bearer token, self-signed cert) ---
P1_IP=192.168.0.157
P1_TOKEN=REPLACE_ME

# --- MyEmitter EMS (solar / battery / dynamic price) ---
EMS_URL=http://192.168.0.122/api/ems/measurements

# --- Smart plugs (v1 API, HTTP), comma-separated IPs ---
PLUG_IPS=192.168.0.49,192.168.0.110,192.168.0.111,192.168.0.113,192.168.0.114,192.168.0.115,192.168.0.116,192.168.0.117,192.168.0.118,192.168.0.119,192.168.0.120

# Optional per-IP metadata (JSON): {"192.168.0.49":{"name":"Coffee","room":"Kitchen"}}
DEVICE_META_JSON={}

# --- Default prices (seed the settings table on first boot) ---
PRICE_ELECTRICITY_EUR_KWH=0.30
PRICE_GAS_EUR_M3=1.15
PRICE_WATER_EUR_M3=5.20
EXPORT_PRICE_FACTOR=0.65
PRICE_PLUG_EUR_KWH=0.30

# --- Alert thresholds ---
ALERT_HIGH_POWER_W=7000
ALERT_BATTERY_LOW_SOC=15
